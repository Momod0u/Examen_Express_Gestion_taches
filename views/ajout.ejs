<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Ajouter une tâche</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container mt-4">

    <!--  NAVIGATION -->
    <div class="d-flex gap-3 mb-4 justify-content-center">
        <a href="/" class="btn btn-outline-primary btn-lg px-5">
            <i class="bi bi-house-fill me-2"></i>Accueil
        </a>
        <a href="/ajout" class="btn btn-success btn-lg px-5">
            <i class="bi bi-plus-circle-fill me-2"></i>Ajouter
        </a>
        <a href="/dashboard" class="btn btn-outline-secondary btn-lg px-5">
            <i class="bi bi-bar-chart-fill me-2"></i>Dashboard
        </a>
    </div>

    <!-- FORMULAIRE -->
    <div class="card mb-4">
        <div class="card-header bg-success text-white">
            <i class="bi bi-plus-circle-fill me-2"></i>Ajouter une tâche
        </div>
        <div class="card-body">
            <form method="POST" action="/add">

                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-type me-1"></i>Titre</label>
                    <input type="text" name="titre" class="form-control" required>
                </div>

                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-text-paragraph me-1"></i>Description</label>
                    <textarea name="description" class="form-control" rows="3" required></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-flag-fill me-1"></i>Priorité</label>
                    <select name="priorite" class="form-select" required>
                        <option value="basse">Basse</option>
                        <option value="moyenne">Moyenne</option>
                        <option value="haute">Haute</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-clipboard-check me-1"></i>Statut</label>
                    <select name="statut" class="form-select">
                        <option value="a faire">À faire</option>
                        <option value="en cours">En cours</option>
                        <option value="termine">Terminée</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-calendar-event me-1"></i>Date limite</label>
                    <input type="date" name="date_limite" class="form-control" required>
                </div>

                <div class="mb-3">
                    <label class="form-label"><i class="bi bi-person-fill me-1"></i>Responsable</label>
                    <input type="text" name="responsable" class="form-control" required>
                </div>

                <button type="submit" class="btn btn-success px-4">
                    <i class="bi bi-check-circle-fill me-2"></i>Ajouter
                </button>
                <a href="/" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-x-circle me-2"></i>Annuler
                </a>

            </form>
        </div>
    </div>

</div>
</body>
</html>