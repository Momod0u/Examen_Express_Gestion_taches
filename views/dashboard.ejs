<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container mt-4">

    <!-- BOUTONS  -->
    <div class="d-flex gap-3 mb-4 justify-content-center">
        <a href="/" class="btn btn-outline-primary btn-lg px-5">
            <i class="bi bi-house-fill me-2"></i>Accueil
        </a>
        <a href="/ajout" class="btn btn-outline-success btn-lg px-5">
            <i class="bi bi-plus-circle-fill me-2"></i>Ajouter
        </a>
        <a href="/dashboard" class="btn btn-secondary btn-lg px-5">
            <i class="bi bi-bar-chart-fill me-2"></i>Dashboard
        </a>
    </div>

    <!--  STATISTIQUES -->
    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="card text-white bg-primary text-center p-3">
                <i class="bi bi-clipboard-fill mb-2" style="font-size:2.5rem"></i>
                <h2 class="fw-bold"><%= taches.length %></h2>
                <p class="mb-0">Total des tâches</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-success text-center p-3">
                <i class="bi bi-check-circle-fill mb-2" style="font-size:2.5rem"></i>
                <h2 class="fw-bold"><%= taches.filter(t => t.statut === 'termine').length %></h2>
                <p class="mb-0">Tâches terminées</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-info text-center p-3">
                <i class="bi bi-percent mb-2" style="font-size:2.5rem"></i>
                <h2 class="fw-bold">
                    <%= taches.length > 0 ? Math.round(taches.filter(t => t.statut === 'termine').length / taches.length * 100) : 0 %>%
                </h2>
                <p class="mb-0">Pourcentage terminé</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-danger text-center p-3">
                <i class="bi bi-exclamation-triangle-fill mb-2" style="font-size:2.5rem"></i>
                <h2 class="fw-bold">
                    <%= taches.filter(t => t.statut !== 'termine' && new Date(t.date_limite) < new Date()).length %>
                </h2>
                <p class="mb-0">Tâches en retard</p>
            </div>
        </div>

    </div>

</div>
</body>
</html>