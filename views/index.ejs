<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Gestion des  Taches</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body class="bg-light">
<div class="container mt-1">

    <!-- BOUTONS  -->
    <div class="d-flex gap-3 mb-5 justify-content-center">
        <a href="/" class="btn btn-primary btn-lg px-5">
            <i class="bi bi-house-fill me-2"></i>Accueil
        </a>
        <a href="/ajout" class="btn btn-outline-success btn-lg px-5">
            <i class="bi bi-plus-circle-fill me-2"></i>Ajouter
        </a>
        <a href="/dashboard" class="btn btn-outline-secondary btn-lg px-5">
            <i class="bi bi-bar-chart-fill me-2"></i>Dashboard
        </a>
    </div>

    <!-- FILTRES -->
    <div class="card mb-5">
        <div class="card-header bg-primary text-white">
            <i class="bi bi-funnel-fill me-2"></i>Recherche et filtres
        </div>
        <div class="card-body">
            <form method="GET" action="/">
                <div class="row g-2">
                    <div class="col-md-4">
                        <input type="text" name="search" class="form-control" placeholder="Rechercher...">
                    </div>
                    <div class="col-md-3">
                        <select name="statut" class="form-select">
                            <option value="">Tous les statuts</option>
                            <option value="a faire">À faire</option>
                            <option value="en cours">En cours</option>
                            <option value="termine">Terminée</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <select name="priorite" class="form-select">
                            <option value="">Toutes priorités</option>
                            <option value="basse">Basse</option>
                            <option value="moyenne">Moyenne</option>
                            <option value="haute">Haute</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-success w-100">
                            <i class="bi bi-search me-1"></i>Filtrer
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- LISTE DES TACHES -->
    <div class="card mb-5">
        <div class="card-header bg-primary text-white">
            <i class="bi bi-list-task me-2"></i>Liste des tâches
        </div>
        <div class="card-body">
            <table class="table table-bordered table-hover text-center align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Titre</th>
                        <th>Priorité</th>
                        <th>Statut</th>
                        <th>Date limite</th>
                        <th>Responsable</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (taches.length === 0) { %>
                        <tr>
                            <td colspan="6" class="text-muted">
                                <i class="bi bi-inbox me-2"></i>Aucune tâche enregistrée
                            </td>
                        </tr>
                    <% } else { %>
                        <% taches.forEach(tache => { %>
                        <tr>
                            <td><%= tache.titre %></td>
                            <td>
                                <% if (tache.priorite === 'haute') { %>
                                    <span class="badge bg-danger"><i class="bi bi-flag-fill me-1"></i><%= tache.priorite %></span>
                                <% } else if (tache.priorite === 'moyenne') { %>
                                    <span class="badge bg-warning text-dark"><i class="bi bi-flag-fill me-1"></i><%= tache.priorite %></span>
                                <% } else { %>
                                    <span class="badge bg-success"><i class="bi bi-flag-fill me-1"></i><%= tache.priorite %></span>
                                <% } %>
                            </td>
                            <td>
                                <% if (tache.statut === 'termine') { %>
                                    <span class="badge bg-success"><i class="bi bi-check-circle-fill me-1"></i><%= tache.statut %></span>
                                <% } else if (tache.statut === 'en cours') { %>
                                    <span class="badge bg-info text-dark"><i class="bi bi-arrow-repeat me-1"></i><%= tache.statut %></span>
                                <% } else { %>
                                    <span class="badge bg-secondary"><i class="bi bi-hourglass me-1"></i><%= tache.statut %></span>
                                <% } %>
                            </td>
                            <td><%= tache.date_limite %></td>
                            <td><i class="bi bi-person-fill me-1"></i><%= tache.responsable %></td>
                            <td>
                                <a href="/edit/<%= tache.id %>" class="btn btn-sm btn-warning me-1">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>
                                <a href="/delete/<%= tache.id %>" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash-fill"></i>
                                </a>
                            </td>
                        </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

</div>
</body>
</html>